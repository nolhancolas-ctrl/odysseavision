};


async function compressPreviewFile(file: File) {
  if (!file.type.startsWith("image/")) {
    return file;
  }

  if (file.type === "image/svg+xml" || file.type === "image/gif") {
    return file;
  }

  const maxSize = 2200;
  const quality = 0.82;
  const imageUrl = URL.createObjectURL(file);

  try {
    const image = await new Promise<HTMLImageElement>((resolve, reject) => {
      const img = new Image();
      img.onload = () => resolve(img);
      img.onerror = reject;
      img.src = imageUrl;
    });

    const scale = Math.min(1, maxSize / Math.max(image.width, image.height));

    if (scale === 1 && file.size < 4 * 1024 * 1024) {
      return file;
    }

    const canvas = document.createElement("canvas");
    canvas.width = Math.max(1, Math.round(image.width * scale));
    canvas.height = Math.max(1, Math.round(image.height * scale));

    const context = canvas.getContext("2d");

    if (!context) {
      return file;
    }

    context.drawImage(image, 0, 0, canvas.width, canvas.height);

    const blob = await new Promise<Blob | null>((resolve) => {
      canvas.toBlob(resolve, "image/webp", quality);
    });

    if (!blob) {
      return file;
    }

    const cleanName = file.name.replace(/\.[^.]+$/, "") || "preview";

    return new File([blob], `${cleanName}.webp`, {
      type: "image/webp",
      lastModified: Date.now(),
    });
  } finally {
    URL.revokeObjectURL(imageUrl);
  }
}


async function uploadPreviewImage(formData: FormData): Promise<UploadResult> {
  const response = await fetch("/api/admin/uploads/image", {
    method: "POST",
    body: formData,
  });

  const result = (await response.json().catch(() => ({
    ok: false,
    error: response.statusText || "Upload failed.",
    path: "",
  }))) as UploadResult;

  if (!response.ok) {
    return {
      ok: false,
      error: result.error || "Upload failed.",
      path: "",
    };
  }

  return result;
}

function AdminSelect({
  name,
  value,
  formValue,
  onChange,
  options,
}: {
  name: string;
  value: string;
  formValue?: string;
  onChange: (value: string) => void;
  options: SelectOption[];
}) {
  const [open, setOpen] = useState(false);
  const selected = options.find((option) => option.value === value) ?? options[0];

  return (
    <div className="relative">
      <input type="hidden" name={name} value={formValue ?? value} />

      <button
        type="button"
        onClick={() => setOpen((current) => !current)}
        onBlur={() => window.setTimeout(() => setOpen(false), 120)}
        className="flex w-full cursor-pointer items-center justify-between rounded-2xl border border-[#242617]/10 bg-[#f4efe4]/80 px-4 py-3 text-left text-sm text-[#242617] outline-none transition hover:border-[#b88a3b]/50 focus:border-[#b88a3b]/70"
      >
        <span className="min-w-0 truncate">{selected.label}</span>
        <span
          className={`ml-3 text-lg leading-none text-[#242617]/60 transition ${
            open ? "rotate-180" : ""
          }`}
        >
          ⌄
        </span>
      </button>

      {open ? (
        <div className="absolute left-0 right-0 top-[calc(100%+8px)] z-40 overflow-hidden rounded-2xl border border-[#242617]/10 bg-[#f4efe4] p-1 shadow-[0_24px_70px_rgba(20,20,10,0.16)]">
          {options.map((option) => (
            <button
              key={option.value || "empty"}
              type="button"
              onMouseDown={(event) => event.preventDefault()}
              onClick={() => {
                onChange(option.value);
                setOpen(false);
              }}
              className={`flex w-full cursor-pointer rounded-xl px-4 py-3 text-left text-sm transition ${
                option.value === value
                  ? "bg-[#071008] text-[#f4efe4]"
                  : "text-[#242617]/70 hover:bg-white/60 hover:text-[#242617]"
              }`}
            >
              {option.label}
            </button>
          ))}
        </div>
      ) : null}
    </div>
  );
}

function makePreviewId() {
  return `preview-${Date.now()}-${Math.random().toString(16).slice(2)}`;
}

export function AlbumForm({
  album,
  clients,
  action,
  submitLabel,
}: AlbumFormProps) {
  const [coverSrc, setCoverSrc] = useState(album?.coverSrc ?? "");
  const coverInputRef = useRef<HTMLInputElement | null>(null);
  const [coverUploadError, setCoverUploadError] = useState("");
  const [isCoverUploading, setIsCoverUploading] = useState(false);
  const [isCoverDragging, setIsCoverDragging] = useState(false);
  const [status, setStatus] = useState(album?.status ?? "DRAFT");
  const [clientId, setClientId] = useState(album?.clientId ?? "");
  const [previewImages, setPreviewImages] = useState<PreviewImage[]>(() =>
    (album?.images ?? []).map((image, index) => ({
      id: image.id,
      imageSrc: image.imageSrc,
      title: image.title ?? "",
      alt: image.alt ?? image.title ?? "",
      order: image.order ?? index,
    })),
  );
  const [previewError, setPreviewError] = useState("");
  const [isDraggingPreviews, setIsDraggingPreviews] = useState(false);
  const [isUploadingPreviews, startPreviewUpload] = useTransition();
  const previewInputRef = useRef<HTMLInputElement | null>(null);

  const uploadSlug = album?.slug || album?.id || "draft";
  const isCreatingNewClient = clientId === CREATE_NEW_CLIENT_VALUE;

  const clientOptions = useMemo<SelectOption[]>(
    () => [
      { value: "", label: "No client" },
      { value: CREATE_NEW_CLIENT_VALUE, label: "Create new client" },
      ...clients.map((client) => ({
        value: client.id,
        label: `${client.firstName} ${client.lastName ?? ""}${
          client.email ? ` — ${client.email}` : ""
        }`,
      })),
    ],
    [clients],
  );

  const previewPayload = useMemo(
    () =>
      JSON.stringify(
        previewImages.map((image, index) => ({
          imageSrc: image.imageSrc,
          title: image.title,
          alt: image.alt || image.title,
          order: index,
        })),
      ),
    [previewImages],
  );

  function removePreviewImage(index: number) {
    setPreviewImages((current) =>
      current
        .filter((_, imageIndex) => imageIndex !== index)
        .map((image, imageIndex) => ({ ...image, order: imageIndex })),
    );
  }

  function uploadPreviewFiles(files: FileList | File[]) {
    const imageFiles = Array.from(files).filter((file) =>
      file.type.startsWith("image/"),
    );

    if (imageFiles.length === 0) {
      return;
    }

    setPreviewError("");

    startPreviewUpload(async () => {
      const uploaded: PreviewImage[] = [];

      for (const [index, originalFile] of imageFiles.entries()) {
        const file = await compressPreviewFile(originalFile);
        const formData = new FormData();
        const slotId = `${Date.now()}-${index}-${file.name}`;

        formData.append("file", file);
        formData.append("context", "client-album");
        formData.append("entitySlug", uploadSlug);
        formData.append("slotKey", `preview-${slotId}`);
        formData.append("label", "Album preview image");

        const result = await uploadPreviewImage(formData);

        if (!result.ok) {
          setPreviewError(`${originalFile.name}: ${result.error || "Upload failed."}`);
          continue;
        }

        uploaded.push({
          id: makePreviewId(),
          imageSrc: result.path,
          title: "",
          alt: "",
          order: previewImages.length + uploaded.length,
        });
      }

      if (uploaded.length > 0) {
        setPreviewImages((current) =>
          [...current, ...uploaded].map((image, index) => ({
            ...image,
            order: index,
          })),
        );
      }
    });
  }

  function handlePreviewDrop(event: DragEvent<HTMLButtonElement>) {
    event.preventDefault();
    setIsDraggingPreviews(false);
    uploadPreviewFiles(event.dataTransfer.files);
  }


  async function uploadCoverFile(originalFile: File) {
    setCoverUploadError("");
    setIsCoverUploading(true);

    try {
      const file = await compressPreviewFile(originalFile);
      const formData = new FormData();

      formData.append("file", file);
      formData.append("context", "client-album");
      formData.append("entitySlug", slugPreview || "draft");
      formData.append("slotKey", "cover");
      formData.append("label", "Album cover image");

      const result = await uploadPreviewImage(formData);

      if (!result.ok || !result.path) {
        setCoverUploadError(
          `${originalFile.name}: ${result.error || "Upload failed."}`,
        );
        return;
      }

      setCoverSrc(result.path);
    } catch (error) {
      console.error("[AlbumForm] Cover upload failed:", error);
      setCoverUploadError(`${originalFile.name}: Upload failed.`);
    } finally {
      setIsCoverUploading(false);

      if (coverInputRef.current) {
        coverInputRef.current.value = "";
      }
    }
  }


