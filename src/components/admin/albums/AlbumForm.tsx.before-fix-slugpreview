                  <span className="flex h-14 w-14 items-center justify-center rounded-full border border-[#242617]/10 text-3xl text-[#242617]/45">
                    +
                  </span>
                  <span className="text-[11px] font-semibold uppercase tracking-[0.18em] text-[#242617]/45">
                    Album cover image
                  </span>
                  <span className="max-w-xs text-sm leading-6 text-[#242617]/40">
                    {isCoverUploading
                      ? "Uploading image..."
                      : "Drop an image here or click to upload."}
                  </span>
                </span>
              )}

              {coverSrc ? (
                <span className="absolute inset-x-4 bottom-4 rounded-2xl bg-[#071321]/72 px-4 py-3 text-xs font-semibold uppercase tracking-[0.14em] text-[#f4efe4] opacity-0 backdrop-blur transition group-hover:opacity-100">
                  {isCoverUploading ? "Uploading..." : "Replace image"}
                </span>
              ) : null}
            </button>

            <input
              ref={coverInputRef}
              type="file"
              accept="image/jpeg,image/png,image/webp,image/gif,image/svg+xml"
              className="hidden"
              onChange={(event) => {
                const file = event.target.files?.[0];

                if (file) {
                  void uploadCoverFile(file);
                }
