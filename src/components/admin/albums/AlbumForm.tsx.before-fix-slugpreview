            <label className="block">
              <span className="mb-2 block text-xs font-semibold uppercase tracking-[0.18em] text-[#242617]/45">
                Download link
              </span>
              <input
                name="externalDownloadUrl"
                type="url"
                defaultValue={album?.externalDownloadUrl ?? ""}
                className="w-full rounded-2xl border border-[#242617]/10 bg-white/55 px-4 py-3 text-sm text-[#242617] outline-none transition focus:border-[#b88a3b]/70"
                placeholder="https://swisstransfer.com/..."
              />
            </label>

            <p className="mt-3 text-xs leading-5 text-[#242617]/40">
              Use this for SwissTransfer, Google Drive, WeTransfer or any external delivery link.
            </p>
          </div>

          <label className="flex items-center gap-3 rounded-2xl border border-[#242617]/10 bg-[#f4efe4]/80 px-4 py-3 text-sm text-[#242617]/70">
            <input
              type="checkbox"
              name="allowShare"
              defaultChecked={album?.allowShare ?? true}
              className="h-4 w-4 accent-[#b88a3b]"
            />
            Allow sharing
          </label>
        </div>

        <div className="flex flex-nowrap items-center gap-3">
          {album?.slug ? (
            <Link
              href={`/client-albums/${album.slug}`}
              target="_blank"
              rel="noopener noreferrer"
              className="shrink-0 rounded-full border border-[#242617]/15 px-5 py-3 text-xs font-bold uppercase tracking-[0.18em] text-[#242617]/55 transition hover:border-[#b88a3b]/60 hover:text-[#b88a3b]"
            >
              Preview
            </Link>
          ) : null}

          <button
            type="submit"
            className="min-w-[180px] flex-1 rounded-full bg-[#071008] px-5 py-3 text-xs font-bold uppercase tracking-[0.18em] text-[#f4efe4] transition hover:bg-[#b88a3b] hover:text-[#071008]"
          >
            {submitLabel}
          </button>

          <Link
            href="/admin/albums"
            className="shrink-0 rounded-full border border-[#242617]/15 px-5 py-3 text-xs font-bold uppercase tracking-[0.18em] text-[#242617]/55 transition hover:border-[#b88a3b]/60 hover:text-[#b88a3b]"
          >
            Cancel
          </Link>
        </div>
      </aside>
    </form>
  );
}
