                event.preventDefault();
                setIsCoverDragging(true);
              }}
              onDragLeave={() => setIsCoverDragging(false)}
              onDrop={(event) => {
                event.preventDefault();
                setIsCoverDragging(false);

                const file = event.dataTransfer.files[0];

                if (file) {
                  void uploadCoverFile(file);
                }
