import Link from "next/link";
import {
  getSubscriberInsightData,
  type ChartPoint,
} from "@/lib/admin/insights";

export const dynamic = "force-dynamic";

function MetricCard({
  label,
  value,
  detail,
  href,
  actionLabel,
}: {
  label: string;
  value: string | number;
  detail: string;
  href?: string;
  actionLabel?: string;
}) {
  const content = (
    <>
      <p className="text-[11px] font-semibold uppercase tracking-[0.22em] text-[#242617]/45">
        {label}
      </p>
      <p className="mt-3 font-serif text-5xl leading-none text-[#242617]">
        {value}
      </p>
      <div className="mt-3 flex flex-wrap items-center justify-between gap-3">
        <p className="text-sm text-[#2b6b3c]">{detail}</p>
        {actionLabel ? (
          <span className="rounded-full border border-[#242617]/10 px-3 py-1.5 text-[9px] font-semibold uppercase tracking-[0.16em] text-[#242617]/45">
            {actionLabel}
          </span>
        ) : null}
      </div>
    </>
  );

  if (href) {
    return (
      <Link
        href={href}
        className="rounded-[2rem] border border-[#242617]/10 bg-white/45 p-5 shadow-[0_18px_50px_rgba(20,20,10,0.06)] transition hover:-translate-y-0.5 hover:bg-white/65"
      >
        {content}
      </Link>
    );
  }

  return (
    <article className="rounded-[2rem] border border-[#242617]/10 bg-white/45 p-5 shadow-[0_18px_50px_rgba(20,20,10,0.06)]">
      {content}
    </article>
  );
}

function BarChart({ points }: { points: ChartPoint[] }) {
  const max = Math.max(1, ...points.map((point) => point.value));

  return (
    <div className="rounded-[2rem] border border-[#242617]/10 bg-white/45 p-5 shadow-[0_18px_50px_rgba(20,20,10,0.06)]">
      <div className="flex items-center justify-between gap-4">
        <div>
          <p className="text-[11px] font-semibold uppercase tracking-[0.22em] text-[#b88a3b]">
            Growth
          </p>
          <h2 className="mt-2 font-serif text-3xl text-[#242617]">
            Subscribers over time
          </h2>
        </div>
        <span className="rounded-full border border-[#242617]/10 px-4 py-2 text-xs uppercase tracking-[0.16em] text-[#242617]/45">
          Last 30 days
        </span>
      </div>

      {points.length > 0 ? (
        <div className="mt-8 flex h-[260px] items-end gap-2 overflow-x-auto pb-2">
          {points.map((point) => {
            const height = Math.max(8, (point.value / max) * 100);

            return (
              <div
                key={point.title}
                className="flex min-w-10 flex-1 flex-col items-center justify-end gap-3"
              >
                <div
                  className="w-full rounded-t-2xl bg-[#b88a3b]"
                  style={{ height: `${height}%` }}
                  title={`${point.title}: ${point.value}`}
                />
                <span className="text-[10px] uppercase tracking-[0.12em] text-[#242617]/38">
                  {point.label}
                </span>
              </div>
            );
          })}
        </div>
      ) : (
        <p className="mt-8 rounded-3xl border border-[#242617]/10 bg-[#f4efe4]/60 p-6 text-sm text-[#242617]/50">
          No subscriber activity yet.
        </p>
      )}
    </div>
  );
}

export default async function SubscribersAnalyticsPage() {
  const data = await getSubscriberInsightData();

  return (
    <div className="space-y-7">
      <section className="flex flex-col justify-between gap-5 md:flex-row md:items-end">
        <div>
          <p className="text-xs font-semibold uppercase tracking-[0.22em] text-[#b88a3b]">
            Audience
          </p>
          <h1 className="mt-3 font-serif text-5xl leading-none tracking-[-0.04em] text-[#242617] md:text-6xl">
            Subscribers
          </h1>
          <p className="mt-4 max-w-2xl text-sm leading-6 text-[#242617]/55">
            Monitor newsletter contacts, recent signups and subscription status.
          </p>
        </div>

        <div className="flex flex-col gap-3 sm:flex-row md:flex-col">
          <Link
            href="/admin/subscribers"
            className="rounded-full border border-[#242617]/12 px-5 py-3 text-center text-xs font-semibold uppercase tracking-[0.16em] text-[#242617]/65 transition hover:bg-white"
          >
            Import subscribers
          </Link>

          <Link
            href="/admin/newsletters/new"
            className="rounded-full bg-[#071321] px-5 py-3 text-center text-xs font-semibold uppercase tracking-[0.16em] text-[#f4efe4] transition hover:bg-[#142844]"
          >
            Create newsletter
          </Link>
        </div>
      </section>

      <section className="grid gap-4 md:grid-cols-3">
        <MetricCard label="Total subscribers" value={data.total} detail="All contacts" href="/admin/subscribers" actionLabel="View all" />
        <MetricCard label="Last 7 days" value={data.last7Days} detail="Recent signups" />
        <MetricCard
          label="Segments"
          value={data.statusCounts.length}
          detail="Detected statuses"
        />
      </section>

      <BarChart points={data.series} />

      <section className="grid gap-5 xl:grid-cols-[0.8fr_1.2fr]">
        <article className="rounded-[2rem] border border-[#242617]/10 bg-white/45 p-5 shadow-[0_18px_50px_rgba(20,20,10,0.06)]">
          <h2 className="font-serif text-3xl text-[#242617]">Status</h2>

          <div className="mt-5 space-y-3">
            {data.statusCounts.length > 0 ? (
              data.statusCounts.map((status) => (
                <div
                  key={status.label}
                  className="flex items-center justify-between gap-4 rounded-3xl border border-[#242617]/8 bg-[#f4efe4]/55 px-4 py-3"
                >
                  <span className="text-sm text-[#242617]/70">{status.label}</span>
                  <span className="rounded-full bg-[#d9ead5] px-3 py-1 text-xs font-semibold text-[#286235]">
                    {status.value}
                  </span>
                </div>
              ))
            ) : (
              <p className="text-sm text-[#242617]/45">No status yet.</p>
            )}
          </div>
        </article>

        <article className="rounded-[2rem] border border-[#242617]/10 bg-white/45 p-5 shadow-[0_18px_50px_rgba(20,20,10,0.06)]">
          <h2 className="font-serif text-3xl text-[#242617]">Recent subscribers</h2>

          <div className="mt-5 overflow-hidden rounded-[1.5rem] border border-[#242617]/8">
            {data.recentSubscribers.length > 0 ? (
              data.recentSubscribers.map((subscriber) => (
                <div
                  key={subscriber.id}
                  className="grid gap-3 border-t border-[#242617]/8 bg-[#f4efe4]/45 p-4 first:border-t-0 md:grid-cols-[1fr_auto]"
                >
                  <div className="min-w-0">
                    <p className="truncate text-sm font-semibold text-[#242617]">
                      {subscriber.name}
                    </p>
                    <p className="mt-1 truncate text-xs text-[#242617]/50">
                      {subscriber.email}
                    </p>
                    <p className="mt-1 text-[11px] uppercase tracking-[0.16em] text-[#242617]/35">
                      {subscriber.source} · {subscriber.date}
                    </p>
                  </div>

                  <span className="h-fit rounded-full bg-[#d9ead5] px-3 py-1 text-xs font-semibold text-[#286235]">
                    {subscriber.status}
                  </span>
                </div>
              ))
            ) : (
              <p className="p-5 text-sm text-[#242617]/45">
                No subscriber yet.
              </p>
            )}
          </div>
        </article>
      </section>

      {!data.available ? (
        <p className="rounded-[2rem] border border-[#242617]/10 bg-white/45 p-5 text-sm text-[#242617]/55">
          Subscriber tracking is not available yet.
        </p>
      ) : null}
    </div>
  );
}
