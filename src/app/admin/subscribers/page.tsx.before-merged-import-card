import Link from "next/link";
import { ConfirmSubmitButton } from "@/components/admin/ConfirmSubmitButton";
import { SubscriberImportFileInput } from "@/components/admin/subscribers/SubscriberImportFileInput";
import { db } from "@/lib/db";
import {
  addNewsletterSubscriber,
  deleteNewsletterSubscriber,
  importNewsletterSubscribers,
  setNewsletterSubscriberActive,
} from "@/server/actions/subscribers";

export const dynamic = "force-dynamic";

type SearchParams = Promise<Record<string, string | string[] | undefined>>;

function formatDate(value: Date) {
  return new Intl.DateTimeFormat("en", {
    dateStyle: "medium",
    timeStyle: "short",
  }).format(value);
}

function getSingleParam(value: string | string[] | undefined) {
  return Array.isArray(value) ? value[0] : value;
}

function getFilter(value: string | string[] | undefined) {
  const filter = getSingleParam(value);

  if (filter === "active" || filter === "inactive") {
    return filter;
  }

  return "all";
}

function getStatusMessage(params: Record<string, string | string[] | undefined>) {
  const status = getSingleParam(params.subscribers);
  const count = getSingleParam(params.count);

  if (status === "added") return "Subscriber added.";
  if (status === "updated") return "Subscriber updated.";
  if (status === "deleted") return "Subscriber deleted.";
  if (status === "invalid-email") return "Please enter a valid email address.";
  if (status === "empty-import") return "No valid email address found in import.";
  if (status === "import-too-large") return "Import file is too large.";
  if (status === "imported") return `${count || "Some"} subscribers imported.`;

  return "";
}

function filterTitle(filter: string) {
  if (filter === "active") return "Active subscribers";
  if (filter === "inactive") return "Unsubscribed";
  return "All subscribers";
}

function MetricCard({
  label,
  value,
  detail,
  href,
  active,
}: {
  label: string;
  value: string | number;
  detail: string;
  href: string;
  active: boolean;
}) {
  return (
    <Link
      href={href}
      className={`rounded-[1.5rem] border px-5 py-4 text-center transition hover:-translate-y-0.5 hover:bg-white/65 ${
        active
          ? "border-[#b88a3b]/45 bg-white/70"
          : "border-[#242617]/10 bg-white/45"
      }`}
    >
      <p className="text-2xl font-semibold text-[#242617]">{value}</p>
      <p className="mt-1 text-[10px] font-bold uppercase tracking-[0.18em] text-[#242617]/45">
        {label}
      </p>
      <p className="mt-2 text-xs text-[#2b6b3c]">{detail}</p>
    </Link>
  );
}

export default async function AdminSubscribersPage({
  searchParams,
}: {
  searchParams: SearchParams;
}) {
  const params = await searchParams;
  const activeFilter = getFilter(params.filter);
  const message = getStatusMessage(params);
  const returnTo =
    activeFilter === "all"
      ? "/admin/subscribers"
      : `/admin/subscribers?filter=${activeFilter}`;

  const subscribers = await db.newsletterSubscriber.findMany({
    orderBy: {
      createdAt: "desc",
    },
  });

  const activeCount = subscribers.filter((subscriber) => subscriber.active).length;
  const inactiveCount = subscribers.length - activeCount;

  const filteredSubscribers = subscribers.filter((subscriber) => {
    if (activeFilter === "active") return subscriber.active;
    if (activeFilter === "inactive") return !subscriber.active;

    return true;
  });

  return (
    <div className="space-y-8">
      <section className="flex flex-col gap-5 lg:flex-row lg:items-end lg:justify-between">
        <div>
          <p className="text-xs font-semibold uppercase tracking-[0.28em] text-[#b88a3b]">
            Newsletter
          </p>

          <h1 className="mt-3 font-serif text-5xl leading-none tracking-[-0.04em] text-[#242617] md:text-6xl">
            Subscribers
          </h1>

          <p className="mt-4 max-w-2xl text-sm leading-6 text-[#242617]/60">
            Add, import and manage the audience used by newsletter campaigns.
          </p>
        </div>

        <div className="grid grid-cols-3 gap-3">
          <MetricCard
            label="Total"
            value={subscribers.length}
            detail="All contacts"
            href="/admin/subscribers"
            active={activeFilter === "all"}
          />
          <MetricCard
            label="Active"
            value={activeCount}
            detail="Will receive emails"
            href="/admin/subscribers?filter=active"
            active={activeFilter === "active"}
          />
          <MetricCard
            label="Unsubscribed"
            value={inactiveCount}
            detail="Disabled contacts"
            href="/admin/subscribers?filter=inactive"
            active={activeFilter === "inactive"}
          />
        </div>
      </section>

      {message ? (
        <div className="rounded-[2rem] border border-[#242617]/10 bg-white/50 px-5 py-4 text-sm text-[#242617]/65 shadow-[0_18px_50px_rgba(20,20,10,0.06)]">
          {message}
        </div>
      ) : null}

      <section className="rounded-[2rem] border border-[#242617]/10 bg-white/45 p-6 shadow-[0_22px_70px_rgba(20,20,10,0.07)]">
        <div className="flex flex-col justify-between gap-4 lg:flex-row lg:items-end">
          <div>
            <p className="text-xs font-bold uppercase tracking-[0.22em] text-[#b88a3b]">
              Audience intake
            </p>
            <h2 className="mt-2 font-serif text-3xl text-[#242617]">
              Add or import subscribers
            </h2>
          </div>

          <p className="max-w-xl text-sm leading-6 text-[#242617]/50">
            Add one contact manually or import a list. Existing contacts are
            reactivated automatically.
          </p>
        </div>

        <div className="mt-6 grid gap-5 xl:grid-cols-[0.78fr_1.22fr]">
          <form
            action={addNewsletterSubscriber}
            className="rounded-[1.75rem] border border-[#242617]/8 bg-[#f4efe4]/55 p-5"
          >
            <p className="text-[11px] font-bold uppercase tracking-[0.2em] text-[#242617]/42">
              Single contact
            </p>

            <label className="mt-5 block">
              <span className="text-xs font-bold uppercase tracking-[0.18em] text-[#242617]/45">
                Email
              </span>
              <input
                name="email"
                type="email"
                required
                placeholder="you@example.com"
                className="mt-2 w-full rounded-[1.4rem] border border-[#242617]/10 bg-white/45 px-4 py-4 text-sm text-[#242617] outline-none transition focus:border-[#b88a3b] focus:bg-white"
              />
            </label>

            <button
              type="submit"
              className="mt-5 cursor-pointer rounded-full bg-[#242617] px-5 py-3 text-xs font-bold uppercase tracking-[0.18em] text-[#f4efe4] transition hover:bg-[#b88a3b]"
            >
              Add subscriber
            </button>
          </form>

          <form
            action={importNewsletterSubscribers}
            encType="multipart/form-data"
            className="rounded-[1.75rem] border border-[#242617]/8 bg-[#f4efe4]/55 p-5"
          >
            <p className="text-[11px] font-bold uppercase tracking-[0.2em] text-[#242617]/42">
              Bulk import
            </p>

            <div className="mt-5 grid gap-4 lg:grid-cols-[0.85fr_1.15fr]">
              <SubscriberImportFileInput />

              <label className="block">
                <span className="text-xs font-bold uppercase tracking-[0.18em] text-[#242617]/45">
                  Paste emails
                </span>
                <textarea
                  name="csvText"
                  rows={6}
                  placeholder="email@example.com&#10;hello@example.com&#10;team@example.com"
                  className="mt-2 min-h-[150px] w-full resize-none rounded-[1.6rem] border border-[#242617]/10 bg-white/45 px-5 py-4 text-sm leading-6 text-[#242617] outline-none transition placeholder:text-[#242617]/35 focus:border-[#b88a3b] focus:bg-white"
                />
              </label>
            </div>

            <div className="mt-5 flex flex-col justify-between gap-3 md:flex-row md:items-center">
              <p className="text-xs leading-5 text-[#242617]/40">
                CSV, comma-separated, spaces or one email per line are accepted.
              </p>

              <button
                type="submit"
                className="cursor-pointer rounded-full border border-[#242617]/15 px-5 py-3 text-xs font-bold uppercase tracking-[0.18em] text-[#242617]/70 transition hover:bg-[#242617] hover:text-[#f4efe4]"
              >
                Import subscribers
              </button>
            </div>
          </form>
        </div>
      </section>

      <section className="rounded-[2rem] border border-[#242617]/10 bg-white/45 p-4 shadow-[0_22px_70px_rgba(20,20,10,0.07)]">
        <div className="mb-4 flex flex-col justify-between gap-3 px-2 md:flex-row md:items-end">
          <div>
            <p className="text-xs font-bold uppercase tracking-[0.22em] text-[#b88a3b]">
              Audience list
            </p>
            <h2 className="mt-2 font-serif text-3xl text-[#242617]">
              {filterTitle(activeFilter)}
            </h2>
          </div>

          <p className="text-sm text-[#242617]/45">
            Showing {filteredSubscribers.length} of {subscribers.length} contacts.
          </p>
        </div>

        <div className="overflow-hidden rounded-[1.6rem] border border-[#242617]/10">
          <table className="w-full border-collapse text-left text-sm">
            <thead className="bg-[#242617] text-[#f4efe4]">
              <tr>
                <th className="px-5 py-4 text-xs font-bold uppercase tracking-[0.16em]">
                  Email
                </th>
                <th className="hidden px-5 py-4 text-xs font-bold uppercase tracking-[0.16em] md:table-cell">
                  Source
                </th>
                <th className="hidden px-5 py-4 text-xs font-bold uppercase tracking-[0.16em] lg:table-cell">
                  Created
                </th>
                <th className="px-5 py-4 text-xs font-bold uppercase tracking-[0.16em]">
                  Status
                </th>
                <th className="px-5 py-4 text-right text-xs font-bold uppercase tracking-[0.16em]">
                  Actions
                </th>
              </tr>
            </thead>

            <tbody className="divide-y divide-[#242617]/10">
              {filteredSubscribers.length === 0 ? (
                <tr>
                  <td
                    colSpan={5}
                    className="px-5 py-10 text-center text-sm text-[#242617]/50"
                  >
                    No subscriber in this filter.
                  </td>
                </tr>
              ) : (
                filteredSubscribers.map((subscriber) => (
                  <tr key={subscriber.id} className="bg-[#f4efe4]/45">
                    <td className="px-5 py-4 font-medium text-[#242617]">
                      {subscriber.email}
                    </td>
                    <td className="hidden px-5 py-4 text-[#242617]/55 md:table-cell">
                      {subscriber.source || "manual"}
                    </td>
                    <td className="hidden px-5 py-4 text-[#242617]/55 lg:table-cell">
                      {formatDate(subscriber.createdAt)}
                    </td>
                    <td className="px-5 py-4">
                      <span
                        className={`rounded-full border px-3 py-1 text-[10px] font-bold uppercase tracking-[0.14em] ${
                          subscriber.active
                            ? "border-[#286235]/15 bg-[#d9ead5] text-[#286235]"
                            : "border-[#8a3d2f]/15 bg-[#e8d6d1] text-[#8a3d2f]"
                        }`}
                      >
                        {subscriber.active ? "Active" : "Unsubscribed"}
                      </span>
                    </td>
                    <td className="px-5 py-4">
                      <div className="flex flex-wrap justify-end gap-2">
                        <form
                          action={setNewsletterSubscriberActive.bind(
                            null,
                            subscriber.id,
                            !subscriber.active,
                          )}
                        >
                          <input type="hidden" name="returnTo" value={returnTo} />
                          <button
                            type="submit"
                            className="cursor-pointer rounded-full border border-[#242617]/10 px-3 py-2 text-[10px] font-bold uppercase tracking-[0.14em] text-[#242617]/60 transition hover:bg-[#242617] hover:text-[#f4efe4]"
                          >
                            {subscriber.active ? "Unsubscribe" : "Resubscribe"}
                          </button>
                        </form>

                        <form action={deleteNewsletterSubscriber.bind(null, subscriber.id)}>
                          <input type="hidden" name="returnTo" value={returnTo} />
                          <ConfirmSubmitButton
                            className="cursor-pointer rounded-full border border-red-900/10 px-3 py-2 text-[10px] font-bold uppercase tracking-[0.14em] text-red-900/60 transition hover:bg-red-900 hover:text-white"
                          >
                            Delete
                          </ConfirmSubmitButton>
                        </form>
                      </div>
                    </td>
                  </tr>
                ))
              )}
            </tbody>
          </table>
        </div>
      </section>
    </div>
  );
}
